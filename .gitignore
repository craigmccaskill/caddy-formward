# Built binaries — root-anchored paths so we don't accidentally match
# directories named "posthorn" (e.g., core/cmd/posthorn/ source dir).
/posthorn
/posthorn.bin
/core/posthorn
/bin/

# Test artifacts
*.test
coverage.out

# Local config files (operators write their own)
*.toml.local
config.local.toml

# OS
.DS_Store
